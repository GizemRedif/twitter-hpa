# Merkezi yapılandırma şablonu
# PROJEYİ ÇALIŞTIRMADAN ÖNCE BU DOSYANIN ADINI '.env' OLARAK DEĞİŞTİRİN
# Veya kopyasını oluşturup adını '.env' yapın.
# Gerekli bilgileri doldurun (örneğin AWS_ACCESS_KEY_ID)

# PostgreSQL — Kullanıcı & Şifre (tüm DB'ler için ortak)
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin

# Analytics veritabanı (tweet_metrics, batch_tweet_metrics tabloları)
# Not: Airflow metadata DB (airflow) docker-compose.yml'de ayrıca tanımlanır.
ANALYTICS_DB=twitter_metrics

# Airflow Admin User
AIRFLOW_USER=admin
AIRFLOW_PASSWORD=admin
AIRFLOW_EMAIL=admin@example.com

# AWS S3 / DigitalOcean Spaces credentials (for Parquet Data Lake) 
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=fra1
S3_ENDPOINT_URL=https://fra1.digitaloceanspaces.com  # Required for DO Spaces
S3_BUCKET_NAME=twitter-hpa-datalake

